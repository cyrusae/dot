{
  "hooks": {
    "AfterAgent": [
      {
        "hooks": [
          {
            "command": "exomonad hook after-agent --runtime gemini",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "BeforeTool": [
      {
        "hooks": [
          {
            "command": "exomonad hook before-tool --runtime gemini",
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "mcpServers": {
    "exomonad": {
      "args": [
        "mcp-stdio",
        "--role",
        "dev",
        "--name",
        "server-gaps"
      ],
      "command": "exomonad",
      "type": "stdio"
    }
  }
}